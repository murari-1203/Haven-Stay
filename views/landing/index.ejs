<% layout("layouts/boilerplate") %>

    <style>
        .hs-hero {
            min-height: calc(100vh - 56px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 5rem 1.5rem 4rem;
            background: #faf7f2;
            position: relative;
            overflow: hidden;
        }
        
        .hs-hero::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle, rgba(201, 151, 58, 0.13) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        
        .hs-hero::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: -80px;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle, rgba(122, 92, 68, 0.09) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        
        .hs-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: #f3ede3;
            border: 1px solid #e8ddd0;
            border-radius: 100px;
            padding: 0.3rem 1rem;
            font-size: 0.7rem;
            font-weight: 500;
            color: #7a5c44;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 1.6rem;
        }
        
        .hs-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            background: #c9973a;
            border-radius: 50%;
        }
        
        .hs-title {
            font-family: 'Georgia', serif;
            font-size: clamp(2.8rem, 7vw, 5rem);
            font-weight: 300;
            line-height: 1.08;
            color: #3d2b1f;
            max-width: 680px;
        }
        
        .hs-title em {
            font-style: italic;
            color: #c9973a;
        }
        
        .hs-sub {
            font-size: 1rem;
            line-height: 1.75;
            color: #7a6a5a;
            max-width: 460px;
            margin: 1.2rem auto 0;
        }
        
        .hs-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            background: #3d2b1f;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 500;
            padding: 0.8rem 2rem;
            border-radius: 8px;
            text-decoration: none;
            box-shadow: 0 4px 18px rgba(61, 43, 31, 0.22);
            transition: background 0.2s, transform 0.15s;
        }
        
        .hs-btn-primary:hover {
            background: #7a5c44;
            color: #fff;
            transform: translateY(-2px);
        }
        
        .hs-btn-outline {
            display: inline-flex;
            align-items: center;
            color: #3d2b1f;
            font-size: 0.9rem;
            font-weight: 500;
            padding: 0.8rem 2rem;
            border-radius: 8px;
            border: 1.5px solid #e8ddd0;
            text-decoration: none;
            background: transparent;
            transition: border-color 0.2s, background 0.2s;
        }
        
        .hs-btn-outline:hover {
            border-color: #c8b8a2;
            background: #f3ede3;
            color: #3d2b1f;
        }
        
        .hs-stat-val {
            font-family: 'Georgia', serif;
            font-size: 2rem;
            font-weight: 600;
            color: #3d2b1f;
        }
        
        .hs-stat-lbl {
            font-size: 0.7rem;
            color: #7a6a5a;
            letter-spacing: 0.04em;
        }
        
        .hs-divider {
            width: 1px;
            height: 36px;
            background: #e8ddd0;
        }
        /* Feature strip */
        
        .hs-features {
            background: #fff;
            border-top: 1px solid #e8ddd0;
            border-bottom: 1px solid #e8ddd0;
        }
        
        .hs-feat {
            flex: 1;
            padding: 1.8rem 2rem;
            border-right: 1px solid #e8ddd0;
            transition: background 0.2s;
        }
        
        .hs-feat:last-child {
            border-right: none;
        }
        
        .hs-feat:hover {
            background: #f3ede3;
        }
        
        .hs-feat-title {
            font-family: 'Georgia', serif;
            font-size: 1.05rem;
            font-weight: 600;
            color: #3d2b1f;
            margin: 0.5rem 0 0.3rem;
        }
        
        .hs-feat-desc {
            font-size: 0.8rem;
            line-height: 1.6;
            color: #7a6a5a;
            margin: 0;
        }
        /* CTA strip */
        
        .hs-cta {
            background: #3d2b1f;
            padding: 4rem 3rem;
            position: relative;
            overflow: hidden;
        }
        
        .hs-cta::before {
            content: '';
            position: absolute;
            top: -50px;
            right: 80px;
            width: 200px;
            height: 200px;
            background: rgba(201, 151, 58, 0.12);
            border-radius: 50%;
            pointer-events: none;
        }
        
        .hs-cta-title {
            font-family: 'Georgia', serif;
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 300;
            color: #fff;
            line-height: 1.2;
        }
        
        .hs-cta-sub {
            font-size: 0.88rem;
            color: rgba(255, 255, 255, 0.5);
            margin-top: 0.4rem;
        }
        
        .hs-btn-gold {
            padding: 0.8rem 1.8rem;
            border-radius: 8px;
            background: #c9973a;
            color: #3d2b1f;
            font-size: 0.88rem;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.2s, transform 0.15s;
        }
        
        .hs-btn-gold:hover {
            background: #e8bc6a;
            transform: translateY(-1px);
        }
        
        .hs-btn-ghost-w {
            padding: 0.8rem 1.8rem;
            border-radius: 8px;
            border: 1.5px solid rgba(255, 255, 255, 0.25);
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.88rem;
            font-weight: 500;
            text-decoration: none;
            transition: border-color 0.2s, background 0.2s;
        }
        
        .hs-btn-ghost-w:hover {
            border-color: rgba(255, 255, 255, 0.5);
            background: rgba(255, 255, 255, 0.07);
            color: #fff;
        }
    </style>

    <!-- HERO -->
    <section class="hs-hero">
        <div class="hs-badge">Verified Property Listings</div>

        <h1 class="hs-title">
            Find your next<br/><em>perfect</em> stay
        </h1>

        <p class="hs-sub">
            Curated homes, apartments, and villas listed by verified hosts — trustworthy, transparent, and simple.
        </p>

        <div class="d-flex gap-3 flex-wrap justify-content-center mt-4">
            <a class="hs-btn-primary" href="/signup">
      Get started free
      <i class="fa-solid fa-arrow-right fa-sm"></i>
    </a>
            <a class="hs-btn-outline" href="/listings">Browse listings</a>
        </div>

        <div class="d-flex align-items-center gap-4 mt-5" style="position:relative;z-index:1;">
            <div class="hs-stat text-center">
                <div class="hs-stat-val">2,400+</div>
                <div class="hs-stat-lbl">Active listings</div>
            </div>
            <div class="hs-divider"></div>
            <div class="hs-stat text-center">
                <div class="hs-stat-val">98%</div>
                <div class="hs-stat-lbl">Happy stays</div>
            </div>
            <div class="hs-divider"></div>
            <div class="hs-stat text-center">
                <div class="hs-stat-val">120+</div>
                <div class="hs-stat-lbl">Cities covered</div>
            </div>
        </div>
    </section>

    <!-- FEATURE STRIP -->
    <div class="hs-features d-flex flex-wrap">
        <div class="hs-feat">
            <div style="font-size:1.4rem;">🔍</div>
            <div class="hs-feat-title">Verified Listings</div>
            <p class="hs-feat-desc">Every property is checked before publishing — accurate photos, prices, and details guaranteed.</p>
        </div>
        <div class="hs-feat">
            <div style="font-size:1.4rem;">⚡</div>
            <div class="hs-feat-title">Instant Booking</div>
            <p class="hs-feat-desc">Book directly and get confirmation in minutes. No back-and-forth, no waiting.</p>
        </div>
        <div class="hs-feat">
            <div style="font-size:1.4rem;">🔒</div>
            <div class="hs-feat-title">Secure & Trusted</div>
            <p class="hs-feat-desc">Hosts are ID-verified and rated. All transactions are fully encrypted end-to-end.</p>
        </div>
        <div class="hs-feat">
            <div style="font-size:1.4rem;">💬</div>
            <div class="hs-feat-title">24/7 Support</div>
            <p class="hs-feat-desc">Our team is always on hand for queries, issues, or anything in between.</p>
        </div>
    </div>

    <!-- CTA STRIP -->
    <div class="hs-cta d-flex align-items-center justify-content-between flex-wrap gap-4">
        <div style="position:relative;z-index:1;">
            <div class="hs-cta-title">Ready to find<br/>your haven?</div>
            <div class="hs-cta-sub">Join thousands of renters and hosts today.</div>
        </div>
        <div class="d-flex gap-3 flex-wrap" style="position:relative;z-index:1;">
            <a class="hs-btn-gold" href="/signup">Create free account</a>
            <a class="hs-btn-ghost-w" href="/login">Log in</a>
        </div>
    </div>
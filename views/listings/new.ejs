<% layout("layouts/boilerplate") %>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        .input-icon-wrap~.invalid-feedback,
        .input-prefix~.invalid-feedback {
            display: none;
        }
        
        .was-validated .input-icon-wrap:has(input:invalid)~.invalid-feedback,
        .was-validated .input-prefix:has(input:invalid)~.invalid-feedback {
            display: block;
        }
    </style>

    <div class="form-page">
        <div class="form-card">

            <div class="form-header">
                <h3>Create a new listing</h3>
                <p>Fill in the details below to publish your property</p>
            </div>

            <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="listing[title]" type="text" class="form-control" placeholder="e.g. Cozy beachfront villa in Goa" required>
                    <div class="invalid-feedback">Enter a valid title</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" placeholder="Describe what makes your place special..." required></textarea>
                    <div class="invalid-feedback">Enter a valid description</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Image URL</label>
                    <div class="input-icon-wrap">
                        <i class="fa-regular fa-image input-icon"></i>
                        <input name="listing[image][url]" type="file" class="form-control" placeholder="https://example.com/image.jpg">
                    </div>
                </div>

                <div class="section-divider">Pricing &amp; Location</div>

                <div class="row g-3 mb-3">

                    <div class="col-md-6">
                        <label class="form-label">Price per night</label>
                        <div class="input-prefix">
                            <span>₹</span>
                            <input name="listing[price]" class="form-control" placeholder="0" required>
                        </div>
                        <div class="invalid-feedback">Enter a valid price</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Country</label>
                        <div class="input-icon-wrap">
                            <i class="fa-solid fa-earth-asia input-icon"></i>
                            <input name="listing[country]" type="text" class="form-control" placeholder="e.g. India" required>
                        </div>
                        <div class="invalid-feedback">Enter a valid country</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Category</label>

                        <div class="category-wrap">
                            <i class="fa-solid fa-tag input-icon"></i>

                            <select name="listing[category]" class="category-select w-100" required>
                                <option value="" disabled selected>
                                    Select a category
                                </option>
                            
                                <option value="Beach">🏖️ Beach</option>
                                <option value="Mountains">⛰️ Mountains</option>
                                <option value="Camping">🏕️ Camping</option>
                                <option value="Arctic">🧊 Arctic</option>
                                <option value="Desert">🏜️ Desert</option>
                                <option value="Forest">🌲 Forest</option>
                                <option value="Lake">🏞️ Lake</option>
                                <option value="City">🏙️ City</option>
                                <option value="Countryside">🌾 Countryside</option>
                                <option value="Historical">🏛️ Historical</option>
                                <option value="Castle">🏰 Castle</option>
                                <option value="Farm">🚜 Farm</option>
                                <option value="Luxury">✨ Luxury</option>
                                <option value="Adventure">🧗 Adventure</option>
                           </select>
                        </div>

                        <div class="invalid-feedback">
                            Please select a category
                        </div>
                    </div>

                </div>

                <div class="mb-4">
                    <label class="form-label">Location</label>
                    <div class="input-icon-wrap">
                        <i class="fa-solid fa-location-dot input-icon"></i>
                        <input name="listing[location]" type="text" class="form-control" placeholder="e.g. Manali, Himachal Pradesh" required>
                    </div>
                    <div class="invalid-feedback">Enter a valid location</div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <button type="submit" class="btn-submit">Publish listing</button>
                    <a href="/listings" class="btn-cancel">Cancel</a>
                </div>

            </form>
        </div>
    </div>